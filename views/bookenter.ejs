<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="bookenter.css">
    <style>
        :root {
            --lib-navy: #1e293b;
            --lib-accent: #0ea5e9;
            --border: #e2e8f0;
            --bg: #f8fafc;
        }

        .library-card {
            max-width: 650px;
            margin: 2rem auto;
            background: white;
            padding: 0;
            border-radius: 12px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            font-family: 'Inter', sans-serif;
        }

        .card-header {
            background: var(--lib-navy);
            color: white;
            padding: 20px 30px;
        }

        .card-header h2 {
            margin: 0;
            font-size: 1.5rem;
        }

        .card-header p {
            margin: 5px 0 0;
            font-size: 0.9rem;
            opacity: 0.8;
        }

        .book-form {
            padding: 30px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        label {
            font-size: 0.85rem;
            font-weight: 600;
            color: #64748b;
        }

        input,
        select,
        textarea {
            padding: 10px 14px;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 1rem;
            background-color: var(--bg);
        }

        input:focus,
        select:focus,
        textarea:focus {
            outline: none;
            border-color: var(--lib-accent);
            box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1);
            background-color: white;
        }

        .save-btn {
            background: var(--lib-accent);
            color: white;
            padding: 14px;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: transform 0.1s, background 0.2s;
            margin-top: 10px;
        }

        .save-btn:hover {
            background: #0284c7;
        }

        .save-btn:active {
            transform: scale(0.98);
        }
    </style>
</head>

<body>
    <div class="library-card">
        <div class="card-header">
            <h2>New Book Entry</h2>
            <p>Add a new volume to the library archive</p>
        </div>

<form method="POST" action="/book-register" class="book-form">

    <div class="form-group full-width">
        <label>Book Title</label>
        <input type="text" name="title" required>
    </div>

    <div class="form-row">
        <div class="form-group">
            <label>Author Name</label>
            <input type="text" name="author" required>
        </div>

        <div class="form-group">
            <label>ISBN Number</label>
            <input type="text" name="isbn">
        </div>
    </div>

    <div class="form-row">
        <div class="form-group">
            <label>Genre</label>
            <select name="genre">
                <option value="fiction">Fiction</option>
                <option value="non-fiction">Non-Fiction</option>
                <option value="science">Science</option>
                <option value="history">History</option>
            </select>
        </div>

        <div class="form-group">
            <label>Total Copies</label>
            <input type="number" name="total_copies" required>
        </div>
    </div>

    <div class="form-group full-width">
        <label>Available Copies</label>
        <input type="number" name="available_copies" required>
    </div>

    <button type="submit" class="save-btn">Add Book</button>

</form>
    </div>

</body>
<script src="bookenter.js"></script>

</html>