<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<title>Student Details</title>

<style>
body {
    font-family: 'Segoe UI', sans-serif;
    background: #f1f5f9;
    margin: 0;
    padding: 20px;
}

/* Title */
h2 {
    text-align: center;
    margin-bottom: 20px;
    color: #1e293b;
}

/* Table Styling */
table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    border-radius: 10px;
    overflow: hidden;
}

/* Header */
th {
    background: #1e293b;
    color: white;
    padding: 12px;
    font-size: 14px;
}

/* Rows */
td {
    padding: 10px;
    text-align: center;
    font-size: 14px;
    border-bottom: 1px solid #e2e8f0;
}

/* Zebra striping */
tr:nth-child(even) {
    background: #f8fafc;
}

/* Hover effect */
tr:hover {
    background: #e0f2fe;
}

/* Responsive scroll */
.table-container {
    overflow-x: auto;
}
</style>

</head>

<body>

<h2>📋 Student Details</h2>

<div class="table-container">
<table>

<tr>
    <th>ID</th>
    <th>First Name</th>
    <th>Last Name</th>
    <th>Roll No</th>
    <th>Branch</th>
    <th>Year</th>
    <th>Email</th>
    <th>Phone</th>
    <th>Created</th>
    <th>DOB</th>
    <th>Parent Phone</th>
    <th>Address</th>
    <th>Reg Date</th>
</tr>

<% users.forEach(user => { %>
<tr>
    <td><%= user.id %></td>
    <td><%= user.first_name %></td>
    <td><%= user.last_name %></td>
    <td><%= user.roll_no %></td>
    <td><%= user.branch %></td>
    <td><%= user.year %></td>
    <td><%= user.email %></td>
    <td><%= user.student_phone %></td>
    <td><%= user.created_at %></td>
    <td><%= user.dob %></td>
    <td><%= user.parent_phone %></td>
    <td><%= user.address %></td>
    <td><%= user.registration_date %></td>
</tr>
<% }) %>

</table>
</div>

</body>
</html>